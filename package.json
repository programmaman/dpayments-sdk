{
  "name": "@rakelabs/dpayments-sdk",
  "version": "0.1.0",
  "private": false,
  "description": "npm SDK for Disputable Payments workflows",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "keywords": [
    "payments",
    "ethereum",
    "smart-contracts",
    "kleros",
    "arbitration",
    "defi"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typechain": "typechain --target ethers-v6 --out-dir generated/typechain '../../../frontend/abi/PaymentFactory.json' '../../../frontend/abi/DisputablePayment.json'",
    "posttypechain": "node scripts/patch-typechain.mjs",
    "prebuild": "npm run typechain",
    "build": "tsc",
    "prepack": "npm run build",
    "test": "npm run build && node --test dist/test/*.test.js",
    "test:e2e": "npm run build && node --import tsx/esm --test --test-concurrency=1 test/e2e/*.e2e.test.ts",
    "test:ci": "npm run build && node --test dist/test/*.test.js && node --import tsx/esm --test --test-concurrency=1 test/e2e/*.e2e.test.ts"
  },
  "dependencies": {
    "ethers": "^6.10.0"
  },
  "devDependencies": {
    "@typechain/ethers-v6": "^0.5.1",
    "@types/node": "^20.0.0",
    "tsx": "^4.22.3",
    "typechain": "^8.3.2",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ]
}